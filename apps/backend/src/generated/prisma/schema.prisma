generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  phone     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  contacts      Contact[]
  conversations Conversation[]

  @@map("companies")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(AGENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  conversations Conversation[]

  @@map("users")
}

model Contact {
  id        String   @id @default(cuid())
  phone     String
  name      String?
  email     String?
  tags      String[]
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  conversations Conversation[]

  @@unique([phone, companyId])
  @@map("contacts")
}

model Conversation {
  id        String             @id @default(cuid())
  status    ConversationStatus @default(OPEN)
  stage     String?
  isPaused  Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  companyId  String
  company    Company @relation(fields: [companyId], references: [id])
  contactId  String
  contact    Contact @relation(fields: [contactId], references: [id])
  assignedTo String?
  agent      User?   @relation(fields: [assignedTo], references: [id])

  messages Message[]

  @@map("conversations")
}

model Message {
  id        String      @id @default(cuid())
  wamid     String?     @unique
  body      String?
  type      MessageType @default(TEXT)
  direction Direction
  status    String?
  createdAt DateTime    @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
}

enum ConversationStatus {
  OPEN
  CLOSED
  PENDING
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
}

enum Direction {
  INBOUND
  OUTBOUND
}
