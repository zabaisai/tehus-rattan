generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  phone     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  contacts            Contact[]
  conversations       Conversation[]
  automations         Automation[]
  pipelines           Pipeline[]
  leads               Lead[]
  tasks               Task[]
  notes               Note[]
  products            Product[]
  whatsappIntegration WhatsAppIntegration?

  @@map("companies")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(AGENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId     String
  company       Company            @relation(fields: [companyId], references: [id])
  conversations Conversation[]
  leads         Lead[]
  stageChanges  LeadStageHistory[]
  tasks         Task[]
  notes         Note[]

  @@map("users")
}

model Contact {
  id        String   @id @default(cuid())
  phone     String
  name      String?
  email     String?
  tags      String[]
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  conversations Conversation[]
  leads         Lead[]
  tasks         Task[]

  @@unique([phone, companyId])
  @@map("contacts")
}

model Conversation {
  id            String             @id @default(cuid())
  status        ConversationStatus @default(OPEN)
  stage         String?
  isPaused      Boolean            @default(false)
  channel       String             @default("whatsapp")
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  companyId  String
  company    Company @relation(fields: [companyId], references: [id])
  contactId  String
  contact    Contact @relation(fields: [contactId], references: [id])
  assignedTo String?
  agent      User?   @relation(fields: [assignedTo], references: [id])

  messages Message[]
  notes    Note[]

  @@map("conversations")
}

model Message {
  id        String        @id @default(cuid())
  wamid     String?       @unique
  body      String?
  type      MessageType   @default(TEXT)
  direction Direction
  status    MessageStatus @default(QUEUED)
  createdAt DateTime      @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

// ─────────────────────────────────────────────
// AUTOMATIZACION
// ─────────────────────────────────────────────
model Automation {
  id         String   @id @default(cuid())
  name       String
  isActive   Boolean  @default(true)
  trigger    String
  conditions Json?
  actions    Json
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@map("automations")
}

// ─────────────────────────────────────────────
// CRM CORE: PIPELINE Y LEADS
// ─────────────────────────────────────────────
model Pipeline {
  id        String   @id @default(cuid())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company         @relation(fields: [companyId], references: [id])
  stages    PipelineStage[]
  leads     Lead[]

  @@map("pipelines")
}

model PipelineStage {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  leads      Lead[]

  @@map("pipeline_stages")
}

model Lead {
  id                String     @id @default(cuid())
  title             String
  value             Float?     @default(0)
  status            LeadStatus @default(OPEN)
  lostReason        String?
  expectedCloseDate DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])

  stageId String
  stage   PipelineStage @relation(fields: [stageId], references: [id])

  assignedTo String?
  agent      User?   @relation(fields: [assignedTo], references: [id])

  stageHistory LeadStageHistory[]
  tasks        Task[]
  notes        Note[]

  @@map("leads")
}

model LeadStageHistory {
  id          String   @id @default(cuid())
  fromStageId String?
  toStageId   String
  changedAt   DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id])

  changedBy String?
  user      User?   @relation(fields: [changedBy], references: [id])

  @@map("lead_stage_histories")
}

enum LeadStatus {
  OPEN
  WON
  LOST
}

// ─────────────────────────────────────────────
// TAREAS Y NOTAS
// ─────────────────────────────────────────────
model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  type        TaskType     @default(TASK)
  status      TaskStatus   @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  assignedTo String?
  agent      User?   @relation(fields: [assignedTo], references: [id])

  @@map("tasks")
}

model Note {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  createdBy String?
  user      User?   @relation(fields: [createdBy], references: [id])

  @@map("notes")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  TASK
  FOLLOW_UP
  CALL
  MEETING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// PRODUCTOS
// ─────────────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  code        String?
  name        String
  description String?
  price       Float
  imageUrl    String?
  category    String?
  sku         String?
  stock       Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@map("products")
}

// ─────────────────────────────────────────────
// WHATSAPP INTEGRATION
// ─────────────────────────────────────────────
model WhatsAppIntegration {
  id                   String                    @id @default(cuid())
  displayPhoneNumber   String?
  phoneNumberId        String                    @unique
  wabaId               String?
  status               WhatsAppIntegrationStatus @default(PENDING)
  accessTokenEncrypted String?
  connectedAt          DateTime?
  disconnectedAt       DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  @@map("whatsapp_integrations")
}

enum WhatsAppIntegrationStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  REVOKED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
  ARCHIVED
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}
