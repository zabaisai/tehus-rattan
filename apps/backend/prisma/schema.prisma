generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String        @id @default(cuid())
  name      String
  phone     String?       @unique
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Informational company profile — display-only, never legal/fiscal/billing data.
  slug             String?  @unique
  logoUrl          String?
  secondaryLogoUrl String?
  primaryColor     String?
  accentColor      String?
  backgroundColor  String?
  businessType     String?
  city             String?
  country          String?
  email            String?
  website          String?
  description      String?
  settings         Json?

  users               User[]
  contacts            Contact[]
  conversations       Conversation[]
  automations         Automation[]
  pipelines           Pipeline[]
  leads               Lead[]
  tasks               Task[]
  notes               Note[]
  products            Product[]
  whatsappIntegration WhatsAppIntegration?
  auditLogs           AuditLog[]           @relation("AuditLogAffectedCompany")
  supportSessions     SupportSession[]

  @@map("companies")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(AGENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId       String?
  company         Company?           @relation(fields: [companyId], references: [id])
  conversations   Conversation[]
  leads           Lead[]
  stageChanges    LeadStageHistory[]
  tasks           Task[]
  notes           Note[]
  auditLogs       AuditLog[]         @relation("AuditLogActor")
  supportSessions SupportSession[]

  @@map("users")
}

model Contact {
  id        String   @id @default(cuid())
  phone     String
  name      String?
  email     String?
  tags      String[]
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  conversations Conversation[]
  leads         Lead[]
  tasks         Task[]

  @@unique([phone, companyId])
  @@map("contacts")
}

model Conversation {
  id            String             @id @default(cuid())
  status        ConversationStatus @default(OPEN)
  stage         String?
  isPaused      Boolean            @default(false)
  channel       String             @default("whatsapp")
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  companyId  String
  company    Company @relation(fields: [companyId], references: [id])
  contactId  String
  contact    Contact @relation(fields: [contactId], references: [id])
  assignedTo String?
  agent      User?   @relation(fields: [assignedTo], references: [id])

  messages Message[]
  notes    Note[]

  @@map("conversations")
}

model Message {
  id        String        @id @default(cuid())
  wamid     String?       @unique
  body      String?
  type      MessageType   @default(TEXT)
  direction Direction
  status    MessageStatus @default(QUEUED)
  createdAt DateTime      @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─────────────────────────────────────────────
// AUTOMATIZACION
// ─────────────────────────────────────────────
model Automation {
  id         String   @id @default(cuid())
  name       String
  isActive   Boolean  @default(true)
  trigger    String
  conditions Json?
  actions    Json
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@map("automations")
}

// ─────────────────────────────────────────────
// CRM CORE: PIPELINE Y LEADS
// ─────────────────────────────────────────────
model Pipeline {
  id        String   @id @default(cuid())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company         @relation(fields: [companyId], references: [id])
  stages    PipelineStage[]
  leads     Lead[]

  @@map("pipelines")
}

model PipelineStage {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  leads      Lead[]

  @@map("pipeline_stages")
}

model Lead {
  id                String     @id @default(cuid())
  title             String
  value             Float?     @default(0)
  status            LeadStatus @default(OPEN)
  lostReason        String?
  expectedCloseDate DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])

  stageId String
  stage   PipelineStage @relation(fields: [stageId], references: [id])

  assignedTo String?
  agent      User?   @relation(fields: [assignedTo], references: [id])

  stageHistory LeadStageHistory[]
  tasks        Task[]
  notes        Note[]
  leadProducts LeadProduct[]

  @@map("leads")
}

model LeadProduct {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  // Snapshot of Product.price at the moment it was attached — must not
  // follow future catalog price changes, since quotes built from this later
  // need to reflect the price the lead actually saw.
  unitPrice Float
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@unique([leadId, productId])
  @@map("lead_products")
}

model LeadStageHistory {
  id          String   @id @default(cuid())
  fromStageId String?
  toStageId   String
  changedAt   DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  changedBy String?
  user      User?   @relation(fields: [changedBy], references: [id])

  @@map("lead_stage_histories")
}

enum LeadStatus {
  OPEN
  WON
  LOST
}

// ─────────────────────────────────────────────
// TAREAS Y NOTAS
// ─────────────────────────────────────────────
model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  type        TaskType     @default(TASK)
  status      TaskStatus   @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  assignedTo String?
  agent      User?   @relation(fields: [assignedTo], references: [id])

  @@map("tasks")
}

model Note {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  createdBy String?
  user      User?   @relation(fields: [createdBy], references: [id])

  @@map("notes")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  TASK
  FOLLOW_UP
  CALL
  MEETING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// PRODUCTOS
// ─────────────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  code        String?
  name        String
  description String?
  price       Float
  imageUrl    String?
  category    String?
  sku         String?
  stock       Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  leadProducts LeadProduct[]

  @@map("products")
}

// ─────────────────────────────────────────────
// WHATSAPP INTEGRATION
// ─────────────────────────────────────────────
model WhatsAppIntegration {
  id                   String                    @id @default(cuid())
  displayPhoneNumber   String?
  phoneNumberId        String                    @unique
  wabaId               String?
  status               WhatsAppIntegrationStatus @default(PENDING)
  accessTokenEncrypted String?
  connectedAt          DateTime?
  disconnectedAt       DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  @@map("whatsapp_integrations")
}

enum WhatsAppIntegrationStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  REVOKED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// ─────────────────────────────────────────────
// PLATFORM AUDIT LOG
// ─────────────────────────────────────────────
model AuditLog {
  id                String   @id @default(cuid())
  actorUserId       String?
  actorRole         Role
  affectedCompanyId String?
  action            String
  entityType        String
  entityId          String?
  reason            String?
  metadata          Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())

  actor           User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  affectedCompany Company? @relation("AuditLogAffectedCompany", fields: [affectedCompanyId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId])
  @@index([affectedCompanyId])
  @@index([action])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// PLATFORM SUPPORT SESSIONS
// ─────────────────────────────────────────────
enum SupportSessionStatus {
  ACTIVE
  ENDED
  EXPIRED
}

model SupportSession {
  id          String               @id @default(cuid())
  actorUserId String
  companyId   String
  reason      String
  status      SupportSessionStatus @default(ACTIVE)
  expiresAt   DateTime
  endedAt     DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  actor   User    @relation(fields: [actorUserId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([actorUserId])
  @@index([companyId])
  @@index([status])
  @@index([expiresAt])
  @@map("support_sessions")
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
  ARCHIVED
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}
