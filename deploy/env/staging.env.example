# Template for /opt/tehus-crm/.env.staging on the VPS.
#
# Copy this file, fill in real generated values, then:
#   chmod 600 .env.staging
# NEVER commit the filled-in file. This example intentionally has no
# placeholder values that could be mistaken for real credentials — generate
# everything with `openssl rand ...` as noted below.

# ---- PostgreSQL --------------------------------------------------------
# POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB are consumed directly by the
# postgres:16-alpine image AND must match the credentials embedded in
# DATABASE_URL below — keep all four in sync if you regenerate one.
POSTGRES_DB=
POSTGRES_USER=
# Recommended: openssl rand -base64 24
POSTGRES_PASSWORD=

# Host is the Docker Compose service name "postgres", never localhost —
# backend and postgres only ever talk to each other over the internal
# Docker network.
DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/<POSTGRES_DB>

# ---- Backend runtime ----------------------------------------------------
PORT=3001
NODE_ENV=production

# Required — app.module.ts refuses to boot without it.
# Recommended: openssl rand -base64 32  (>= 32 random bytes)
JWT_SECRET=

# Hashed internally with SHA-256 before use (see
# whatsapp-token-crypto.service.ts) — any long random passphrase works.
# Recommended: openssl rand -base64 32
WHATSAPP_TOKEN_ENCRYPTION_KEY=

# Arbitrary string you also configure in the Meta/WhatsApp app webhook setup.
# Recommended: openssl rand -hex 24
WHATSAPP_VERIFY_TOKEN=

# Used for CORS (main.ts) — must be the exact frontend origin, no trailing slash.
FRONTEND_URL=https://crm-staging.tehusrattan.com

# Onboarding flow guard (see onboarding-invite.guard.ts) — required to create
# a new company through /onboarding.
# Recommended: openssl rand -hex 16
ONBOARDING_INVITE_CODE=

# Consumed once by `node dist/scripts/create-super-admin.js` (see
# docs/VPS_DEPLOYMENT.md) — not read by the running backend app itself.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_NAME=
# Recommended: openssl rand -base64 18  (script requires >= 8 characters)
SUPER_ADMIN_PASSWORD=

# ---- Frontend (build-time) ----------------------------------------------
# Inlined into the client bundle when the frontend image is built (see
# apps/frontend/src/lib/axios.ts) — must be passed as a build ARG, not just
# a runtime variable. deploy.sh reads it from this same file via
# `docker compose --env-file .env.staging ...` so the compose file's
# `args: NEXT_PUBLIC_API_URL: ${NEXT_PUBLIC_API_URL}` resolves correctly.
NEXT_PUBLIC_API_URL=https://api.crm-staging.tehusrattan.com/api
